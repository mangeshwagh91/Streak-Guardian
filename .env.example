# ============================================================
# Streak Guardian — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── GitHub ──────────────────────────────────────────────────
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_NAME=streak-guardian-log
GITHUB_REPO_OWNER=your_github_username
# Branch to commit to (default: main)
GITHUB_BRANCH=main
# Email used for git commits
GITHUB_EMAIL=your_email@example.com

# ── LeetCode ────────────────────────────────────────────────
LEETCODE_USERNAME=your_leetcode_username
LEETCODE_PASSWORD=your_leetcode_password
# Default problem slug to submit if no activity detected
LEETCODE_DEFAULT_PROBLEM_SLUG=two-sum
# Path to solution file relative to solutions/ folder
LEETCODE_DEFAULT_SOLUTION_FILE=problem1.py
# Language ID: 71=python3, 54=cpp, 62=java, 91=javascript
LEETCODE_LANGUAGE_ID=71

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── App ─────────────────────────────────────────────────────
# Timezone (e.g. Asia/Kolkata, America/New_York, UTC)
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
# Port for FastAPI dashboard
DASHBOARD_PORT=8000

# ── Scheduler Times (24h format HH:MM) ──────────────────────
WARNING_CHECK_TIME=22:30
PROTECTION_RUN_TIME=23:45

# ── Database ────────────────────────────────────────────────
DATABASE_PATH=database/streak.db

# ── Security (optional encryption key for config) ───────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
